{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and their meat wallet balance.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "location": { "type": "string" },
        "walletBalance": { "type": "number", "description": "Pre-paid balance in TZS" },
        "loyaltyPoints": { "type": "number" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "walletBalance", "loyaltyPoints", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a product in the butchery or market.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Butchery", "Poultry", "Seafood", "Processed", "African Market", "Specialty"] },
        "subCategory": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["name", "category", "price", "unit"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryAddress": { "type": "string" }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Represents an automatic recurring order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly"] },
        "status": { "type": "string", "enum": ["active", "paused", "cancelled"] },
        "nextOrderDate": { "type": "string", "format": "date-time" },
        "lastOrderDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "productName", "quantity", "price", "frequency", "status", "nextOrderDate", "createdAt"]
    },
    "Redemption": {
      "title": "Loyalty Redemption",
      "description": "Represents a customer's loyalty point redemption for a reward.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "reward": { "type": "string", "enum": ["FREE DELIVERY", "ONE FOR FREE", "DISCOUNT"] },
        "points": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userEmail", "reward", "points", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and wallet data."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Recurring product subscriptions."
    },
    "/redemptions/{redemptionId}": {
      "schema": "Redemption",
      "description": "Loyalty point redemptions."
    }
  }
}
